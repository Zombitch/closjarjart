<!-- Galerie -->
<div class="grid grid-cols-3 gap-2 rounded-2xl overflow-hidden shadow-soft bg-white">
    <% if(photos.length >= 1){ %><div class="col-span-2 overflow-hidden"><img src="<%= photos[0].url %>" alt="Salon" class="photo-hover h-60 sm:h-80 w-full object-cover cursor-pointer" onclick="openLightbox(0)" loading="lazy" decoding="async"/></div><% } %>
    <% if(photos.length >= 2){ %><div class="overflow-hidden"><img src="<%= photos[1].url %>" alt="Cuisine" class="photo-hover h-60 sm:h-80 w-full object-cover cursor-pointer" onclick="openLightbox(1)" loading="lazy" decoding="async"/></div><% } %>
    <% if(photos.length >= 3){ %><div class="overflow-hidden"><img src="<%= photos[2].url %>" alt="Chambre" class="photo-hover h-40 w-full object-cover cursor-pointer" onclick="openLightbox(2)" loading="lazy" decoding="async"/></div><% } %>
    <% if(photos.length >= 4){ %><div class="overflow-hidden"><img src="<%= photos[3].url %>" alt="Salle de bain" class="photo-hover h-40 w-full object-cover cursor-pointer" onclick="openLightbox(3)" loading="lazy" decoding="async"/></div><% } %>
    <% if(photos.length >= 5){ %>
        <div class="relative overflow-hidden">
            <button type="button" class="absolute bottom-2 right-2 z-10 rounded-full bg-white/90 backdrop-blur px-3 py-1 text-xs font-semibold uppercase text-gray-700 shadow hover:bg-white transition cursor-pointer" onclick="openLightbox(4)">voir plus</button>
            <img src="<%= photos[4].url %>" alt="Terrasse" class="photo-hover h-40 w-full object-cover cursor-pointer" onclick="openLightbox(4)" loading="lazy" decoding="async"/>
        </div>
    <% } %>
</div>

<!-- Lightbox / Carousel -->
<div id="photoLightbox" class="hidden fixed inset-0 z-50 bg-black/90 text-white items-center justify-center px-4 py-8" role="dialog" aria-modal="true" aria-label="Galerie photo">
    <button type="button" class="absolute top-5 right-5 rounded-full bg-white/10 p-2 text-white hover:bg-white/20 transition" onclick="closeLightbox()" aria-label="Fermer la galerie">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="m6.225 4.811 13 13-1.414 1.414-13-13z"/><path d="m17.811 4.811 1.414 1.414-13 13-1.414-1.414z"/></svg>
    </button>
    <div class="relative w-full max-w-4xl flex items-center gap-3">
        <button type="button" class="hidden sm:flex p-3 rounded-full bg-white/10 hover:bg-white/20 transition" onclick="previousPhoto()" aria-label="Photo pr&#233;c&#233;dente">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        </button>
        <div id="lightboxImageContainer" class="flex-1">
            <img id="lightboxImage" src="" alt="Galerie Closjarjart" class="w-full max-h-[75vh] object-contain rounded-2xl shadow-soft transition-opacity duration-300" />
            <div class="mt-4 flex justify-between text-xs uppercase tracking-wide opacity-80">
                <span id="lightboxCounter"></span>
            </div>
        </div>
        <button type="button" class="hidden sm:flex p-3 rounded-full bg-white/10 hover:bg-white/20 transition" onclick="nextPhoto()" aria-label="Photo suivante">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
        </button>
    </div>
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-3 sm:hidden">
        <button type="button" class="px-4 py-2 rounded-full bg-white/10 hover:bg-white/20 transition" onclick="previousPhoto()">Pr&#233;c&#233;dente</button>
        <button type="button" class="px-4 py-2 rounded-full bg-white/10 hover:bg-white/20 transition" onclick="nextPhoto()">Suivante</button>
    </div>
</div>
