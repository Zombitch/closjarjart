<%- include('../partials/header.ejs') %>
<body class="bg-gray-50 min-h-screen md:p-4">
  <main class="flex-1 pb-10 flex items-center justify-center">
    <form enctype="multipart/form-data" action="/heart" method="post" class="w-full md:max-w-4xl bg-white rounded-2xl shadow-soft p-6 min-h-[calc(100vh-4rem)] flex flex-col">
      <!-- Tab navigation -->
      <div class="flex border-b mb-4 overflow-x-auto" role="tablist">
        <button type="button" data-tab="price" class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-800 flex items-center gap-1.5 whitespace-nowrap">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 1 0 0 7h5a3.5 3.5 0 1 1 0 7H6"/></svg>
          Prix
        </button>
        <button type="button" data-tab="info" class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-800 flex items-center gap-1.5 whitespace-nowrap">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
          Info
        </button>
        <button type="button" data-tab="photos" class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-800 flex items-center gap-1.5 whitespace-nowrap">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          Photos
        </button>
        <button type="button" data-tab="reservations" class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-800 flex items-center gap-1.5 whitespace-nowrap">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          Reservations
        </button>
        <button type="button" data-tab="stats" class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-800 flex items-center gap-1.5 whitespace-nowrap">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
          Stats
        </button>
      </div>

      <!-- Tab panels (take all vertical space inside the card) -->
      <div class="flex-1 overflow-y-auto">
        <div id="tab-price" class="tab-panel">
          <div class="space-y-5">
            <%- include('../partials/heart/tarifs.ejs') %>
          </div>
        </div>

        <div id="tab-info" class="tab-panel">
          <div class="space-y-5">
            <%- include('../partials/heart/info.ejs') %>
          </div>
        </div>

        <div id="tab-photos" class="tab-panel hidden">
          <h2 class="text-xl font-semibold text-gray-800 mb-3">Photos</h2>
          <%- include('../partials/heart/photos.ejs') %>
        </div>

        <div id="tab-reservations" class="tab-panel hidden">
          <h2 class="text-xl font-semibold text-gray-800 mb-3">Calendrier des r&#233;servations</h2>
          <div class="grid grid-cols-2 gap-2">
            <input type="hidden" id="dateStart" />
            <input id="dateStartISO" name="dateStart" type="hidden" />
            <input type="hidden" id="dateEnd" />
            <input id="dateEndISO" name="dateEnd" type="hidden" />
          </div>
          <div class="flex justify-center space-x-4 mb-6">
            <button type="button" id="addReservationBtn" class="text-sm px-2 py-2 rounded-lg text-white font-medium focus:ring-2 focus:ring-blue-400 focus:outline-none transition" >
              Ajouter
            </button>
            <button type="button" id="editReservationBtn" class="text-sm px-2 py-2 rounded-lg text-white font-medium focus:ring-2 focus:ring-gray-400 focus:outline-none transition">
              Modifier
            </button>
          </div>
          <div id="picker" class="z-50 bg-white border rounded-xl shadow-soft p-3 w-full select-none">
              <div class="flex items-center justify-between mb-2">
                <button type="button" id="prevBtn" class="px-2 py-1 rounded hover:bg-gray-100"><</button>
                <div id="monthLabel" class="font-medium"></div>
                <button type="button" id="nextBtn" class="px-2 py-1 rounded hover:bg-gray-100">></button>
              </div>
              <div class="cal-grid text-xs font-medium text-gray-500 mb-1 text-center">
                <div>Lu</div><div>Ma</div><div>Me</div><div>Je</div><div>Ve</div><div>Sa</div><div>Di</div>
              </div>
              <div id="cal" class="cal-grid"></div>
              <div id="hint" class="mt-2 text-[11px] text-gray-500"></div>
            </div>
        </div>
        <div id="tab-stats" class="tab-panel hidden">
          <div class="space-y-5">
            <%- include('../partials/heart/stats.ejs') %>
          </div>
        </div>
      </div>
      <div class="mt-4 w-full text-center">
        <button type="submit" class="w-1/2 rounded-xl bg-cyan-600 text-white px-4 py-3 font-medium hover:bg-cyan-700 active:scale-[.98] transition-all shadow-sm hover:shadow-md">Enregistrer</button>
      </div>
    </form>
  </main>
  <%- include('../partials/footer.ejs') %>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-15 left-1/2 -translate-x-1/2 text-white px-5 py-3 rounded-full shadow-lg hidden text-sm font-medium"></div>

  <!-- Modal (validate / edit) -->
  <div id="dashboardEditModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <%- include('../partials/heart/modal_calendar_edit.ejs') %>
  </div>
</body>

<script type="text/javascript">
  setConfig(JSON.parse('<%- blockedDate %>'), JSON.parse('<%- config.max_guests %>'), JSON.parse('<%- config.maintenance %>'))
</script>
<script type="text/javascript" src="/static/heart.js?v=<%= assetVersion %>" defer></script>
<script type="text/javascript" src="/static/calendar_dashboard.js?v=<%= assetVersion %>" defer></script>
</html>
