    { id:'hike',        cat:'Extérieur',  label:'Randonnée',        svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="13" cy="4" r="2"/><path d="M9 8l2 5 2-3 3 7"/><path d="M6 21l2-7M17 21l-3-6"/></svg>' },
    { id:'ski',         cat:'Extérieur',  label:'Ski',              svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="17" cy="4" r="2"/><path d="M3 21l7-9 3 3 2-2 6 8"/><path d="M3 21h18"/></svg>' },
    { id:'fishing',     cat:'Extérieur',  label:'Pêche',            svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3l7 7"/><path d="M10.5 10.5l-2 2.5a4 4 0 0 0 5 5l2.5-2"/><path d="M20 8a8 8 0 0 0-8 8"/><path d="M18 5v5h5"/></svg>' },
    { id:'horseback',   cat:'Extérieur',  label:'Équitation',       svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="4" r="2"/><path d="M6 11l2-5 5 2-3 4-2-1z"/><path d="M13 8l3 3-2 6-4-2"/><path d="M7 21l2-7M14 21l1-5"/></svg>' },
    { id:'tent',        cat:'Extérieur',  label:'Camping / Tente',  svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20L12 4l9 16H3z"/><path d="M12 4v16M9 20l3-5 3 5"/></svg>' },
    { id:'mountain',    cat:'Extérieur',  label:'Montagne',         svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3l4 8 5-5 5 13H2L8 3z"/><path d="M4.14 15.08c2.62-1.57 5.24-1.43 7.86.42 2.74 1.94 5.49 2 8.23.19"/></svg>' },
    { id:'river',       cat:'Extérieur',  label:'Rivière / Lac',    svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/><path d="M2 12c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/><path d="M2 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0"/></svg>' },

    // ── Services ─────────────────────────────────────────────────────────────────
    { id:'firstaid',    cat:'Services',   label:'Premiers secours', svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="4"/><path d="M12 8v8M8 12h8"/></svg>' },
    { id:'extinguisher',cat:'Services',   label:'Extincteur',       svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4h2a1 1 0 0 1 1 1v2H6V5a1 1 0 0 1 1-1z"/><rect x="5" y="7" width="8" height="14" rx="2"/><path d="M13 10h3a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-3"/><path d="M9 4V2M7 4V2"/></svg>' },
    { id:'smoke',       cat:'Services',   label:'Détecteur fumée',  svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="5"/><path d="M7 7h10M12 12v10M9 18c0-2 1-3 3-3s3 1 3 3"/></svg>' },
    { id:'accessible',  cat:'Services',   label:'Accès handicapé',  svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="16" cy="4" r="2"/><path d="M11 12h5l2 5H6"/><path d="M11 12l-2-5H6"/><circle cx="9" cy="21" r="2"/><circle cx="19" cy="21" r="2"/></svg>' },
    { id:'elevator',    cat:'Services',   label:'Ascenseur',        svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="2" width="18" height="20" rx="2"/><path d="M9 2v20M9 7l-3-3 3-3M9 17l-3 3 3 3M15 7l3-3-3-3M15 17l3 3-3 3"/></svg>' },
    { id:'concierge',   cat:'Services',   label:'Conciergerie',     svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M12 4a8 8 0 0 1 8 8H4a8 8 0 0 1 8-8z"/><path d="M12 4v3"/></svg>' },
    { id:'breakfast',   cat:'Services',   label:'Petit-déjeuner',   svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><path d="M6 2v2M10 2v2M14 2v2"/></svg>' },
    { id:'safe',        cat:'Services',   label:'Coffre-fort',      svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="12" r="4"/><path d="M12 8v1M12 15v1M8 12h1M15 12h1"/><path d="M18 21v-3"/></svg>' },
    { id:'ev',          cat:'Services',   label:'Borne recharge EV', svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M9 8h4l-2 4h4l-5 8v-6H7l2-6z"/></svg>' },
    { id:'dog',         cat:'Services',   label:'Animaux acceptés', svg:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 5.17A6 6 0 0 0 8 10v4a4 4 0 0 0 8 0v-4a6 6 0 0 0-2-4.83"/><path d="M8 14H5l-2 4h2M16 14h3l2 4h-2"/><circle cx="9" cy="7" r="1" fill="currentColor"/><circle cx="15" cy="7" r="1" fill="currentColor"/><path d="M6 4l2 3M18 4l-2 3"/></svg>' },
  ];

  const CATEGORIES = [...new Set(ICONS.map(function(i){ return i.cat; }))];

  let equipments = [];
  try {
    const raw = document.getElementById('cfg_equipments').value;
    equipments = JSON.parse(raw) || [];
  } catch(e) { equipments = []; }

  let selectedIconId = null;
  let activeCategory = 'all';

  function persist() {
    document.getElementById('cfg_equipments').value = JSON.stringify(equipments);
  }

  function escapeHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderList() {
    const list = document.getElementById('equipmentList');
    const noMsg = document.getElementById('noEquipmentMsg');
    list.innerHTML = '';
    if (equipments.length === 0) {
      noMsg.classList.remove('hidden');
      return;
    }
    noMsg.classList.add('hidden');
    equipments.forEach(function(eq, idx) {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 bg-gray-50 rounded-lg px-3 py-2 border group';
      row.innerHTML =
        '<span class="w-5 h-5 flex-shrink-0 text-gray-600">' + eq.svg + '</span>' +
        '<span class="flex-1 text-sm text-gray-800">' + escapeHtml(eq.label) + '</span>' +
        '<button type="button" onclick="removeEquipment(' + idx + ')" class="text-gray-300 hover:text-red-500 transition text-xl leading-none">&times;</button>';
      list.appendChild(row);
    });
  }

  function renderCategoryTabs() {
    const tabs = document.getElementById('categoryTabs');
    tabs.innerHTML = '';
    ['all'].concat(CATEGORIES).forEach(function(cat) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = cat === 'all' ? 'Toutes' : cat;
      btn.dataset.cat = cat;
      btn.className = 'px-2.5 py-1 rounded-full text-xs font-medium border transition cat-tab ' +
        (cat === activeCategory ? 'bg-cyan-600 text-white border-cyan-600' : 'bg-white text-gray-600 border-gray-300 hover:border-cyan-400 hover:text-cyan-600');
      btn.addEventListener('click', function() {
        activeCategory = cat;
        document.getElementById('iconSearch').value = '';
        renderCategoryTabs();
        renderIconPicker('');
      });
      tabs.appendChild(btn);
    });
  }

  function renderIconPicker(query) {
    const picker = document.getElementById('iconPicker');
    const noResults = document.getElementById('noIconResults');
    const q = (query || '').toLowerCase().trim();
    picker.innerHTML = '';

    const filtered = ICONS.filter(function(icon) {
      const catMatch = activeCategory === 'all' || icon.cat === activeCategory;
      const textMatch = !q || icon.label.toLowerCase().includes(q) || icon.id.includes(q);
      return catMatch && textMatch;
    });

    if (filtered.length === 0) {
      noResults.classList.remove('hidden');
      return;
    }
    noResults.classList.add('hidden');

    filtered.forEach(function(icon) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.title = icon.label;
      btn.dataset.iconId = icon.id;
      const isSelected = icon.id === selectedIconId;
      btn.className = 'icon-pick-btn flex flex-col items-center justify-start gap-1 p-2 rounded-lg border text-center transition cursor-pointer ' +
        (isSelected ? 'bg-cyan-50 border-cyan-400 ring-2 ring-cyan-400' : 'bg-white border-gray-200 hover:bg-cyan-50 hover:border-cyan-300');
      btn.innerHTML =
        '<span class="w-6 h-6 text-gray-600 flex-shrink-0">' + icon.svg + '</span>' +
        '<span class="text-gray-500 text-[9px] leading-tight line-clamp-2 w-full">' + escapeHtml(icon.label) + '</span>';
      btn.addEventListener('click', function() {
        selectedIconId = icon.id;
        document.getElementById('newEquipSvg').value = '';
        renderIconPicker(document.getElementById('iconSearch').value);
      });
      picker.appendChild(btn);
    });
  }

  window.filterIcons = function(query) {
    activeCategory = 'all';
    renderCategoryTabs();
    renderIconPicker(query);
  };

  window.addEquipment = function() {
    const label = document.getElementById('newEquipLabel').value.trim();
    if (!label) { alert('Veuillez saisir un libellé.'); return; }

    let svg = '';
    const customSvg = document.getElementById('newEquipSvg').value.trim();
    if (customSvg) {
      svg = customSvg;
    } else if (selectedIconId) {
      const icon = ICONS.find(function(i){ return i.id === selectedIconId; });
      if (icon) svg = icon.svg;
    }
    if (!svg) { alert('Veuillez choisir une icône ou coller du SVG.'); return; }

    equipments.push({ svg: svg, label: label });
    persist();
    renderList();

    document.getElementById('newEquipLabel').value = '';
    document.getElementById('newEquipSvg').value = '';
    selectedIconId = null;
    renderIconPicker(document.getElementById('iconSearch').value);
  };

  window.removeEquipment = function(idx) {
    equipments.splice(idx, 1);
    persist();
    renderList();
  };

  renderCategoryTabs();
  renderIconPicker('');
  renderList();
})();
</script>
