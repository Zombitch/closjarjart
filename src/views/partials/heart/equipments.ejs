<div class="space-y-5">
  <input type="hidden" id="cfg_equipments" name="equipments" value="<%= JSON.stringify(config.equipments || []) %>" />

  <!-- Current equipment list -->
  <div>
    <h3 class="font-semibold mb-3">Équipements actuels</h3>
    <div id="equipmentList" class="space-y-2">
      <!-- Populated by JS -->
    </div>
    <p id="noEquipmentMsg" class="text-sm text-gray-400 hidden">Aucun équipement ajouté.</p>
  </div>

  <!-- Add new equipment -->
  <div class="border-t pt-4">
    <h3 class="font-semibold mb-3">Ajouter un équipement</h3>
    <div class="space-y-3">
      <div>
        <label class="text-sm text-gray-600 block mb-1">Libellé</label>
        <input type="text" id="newEquipLabel" class="w-full rounded-lg border px-3 py-2 text-sm" placeholder="Ex. Sauna privatif" />
      </div>
      <div>
        <label class="text-sm text-gray-600 block mb-1">Icône</label>
        <div class="grid grid-cols-4 sm:grid-cols-6 gap-2 mb-2" id="iconPicker">
          <!-- Icons rendered by JS -->
        </div>
        <div class="mt-2">
          <label class="text-xs text-gray-500 block mb-1">Ou coller du SVG personnalisé</label>
          <textarea id="newEquipSvg" rows="3" class="w-full rounded-lg border px-3 py-2 text-xs font-mono" placeholder='<svg viewBox="0 0 24 24" fill="currentColor">...</svg>'></textarea>
        </div>
      </div>
      <button type="button" onclick="addEquipment()" class="px-4 py-2 rounded-lg bg-cyan-600 text-white text-sm font-medium hover:bg-cyan-700 transition">
        Ajouter
      </button>
    </div>
  </div>
</div>

<script>
(function() {
  const ICONS = [
    { id: 'kitchen',   label: 'Cuisine',         svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 6h16v12H4z"/><path d="M6 8h12v2H6z"/></svg>' },
    { id: 'heating',  label: 'Chauffage',       svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 4h16v4H4zM4 10h16v10H4z"/></svg>' },
    { id: 'tv',       label: 'TV',              svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 6h18v12H3z"/><circle cx="8" cy="12" r="2"/><circle cx="16" cy="12" r="2"/></svg>' },
    { id: 'linen',    label: 'Linge',           svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 3h14v18H5z"/><path d="M8 7h8v2H8zM8 11h8v2H8zM8 15h5v2H8z"/></svg>' },
    { id: 'sauna',    label: 'Sauna',           svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 2 7l10 5 10-5z"/><path d="M2 17l10 5 10-5"/></svg>' },
    { id: 'iron',     label: 'Fer à repasser',  svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 4h16v4H4zM4 10h16v10H4z"/></svg>' },
    { id: 'hairdryer',label: 'Sèche-cheveux',   svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 3h12l-1 7H7z"/><path d="M9 11h6v10H9z"/></svg>' },
    { id: 'coffee',   label: 'Cafetière',       svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h12v4H6z"/><path d="M5 10h14v10H5z"/><circle cx="12" cy="15" r="2"/></svg>' },
    { id: 'kettle',   label: 'Bouilloire',      svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 3h10v2H6z"/><path d="M5 7h12v11H5z"/><path d="M17 9h2a2 2 0 0 1 0 4h-2z"/></svg>' },
    { id: 'raclette', label: 'Raclette',        svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 7h16v9H4z"/><path d="M8 4h8v3H8z"/><path d="M7 16h2v4H7zM15 16h2v4h-2z"/></svg>' },
    { id: 'fondue',   label: 'Fondue',          svg: '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="10" r="6"/><path d="M8 16h8v5H8z"/></svg>' },
    { id: 'wifi',     label: 'Wifi',            svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M1.5 8.5a17 17 0 0 1 21 0M5 12a12 12 0 0 1 14 0M8.5 15.5a7 7 0 0 1 7 0M12 19h.01"/></svg>' },
    { id: 'parking',  label: 'Parking',         svg: '<svg viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>' },
    { id: 'pool',     label: 'Piscine',         svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M2 20c2-2 4-2 6 0s4 2 6 0 4-2 6 0M2 16c2-2 4-2 6 0s4 2 6 0 4-2 6 0M12 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/></svg>' },
    { id: 'bbq',      label: 'Barbecue',        svg: '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="8"/><path d="M8 12h8M12 8v8"/></svg>' },
    { id: 'garden',   label: 'Jardin',          svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 3 7 3 12c0 3 1.5 5.5 4 7h10c2.5-1.5 4-4 4-7 0-5-3.5-10-9-10z"/><path d="M12 22v-8M9 16l3-4 3 4"/></svg>' },
    { id: 'jacuzzi',  label: 'Jacuzzi',         svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 16h16v4H4z"/><path d="M6 8c0-2 2-4 6-4s6 2 6 4v8H6z"/></svg>' },
    { id: 'bike',     label: 'Vélo',            svg: '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="17" r="3"/><circle cx="19" cy="17" r="3"/><path d="M12 5l-2 7h6L14 5M9 10H5.5"/><path d="M12 5h4l3 5"/></svg>' },
    { id: 'canoe',    label: 'Canoë',           svg: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M2 17c4-3 8-5 20-3M4 13l4-8 4 5"/><path d="M8 5v8"/></svg>' },
    { id: 'game',     label: 'Jeux',            svg: '<svg viewBox="0 0 24 24" fill="currentColor"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h4M8 10v4M15 11h.01M17 13h.01"/></svg>' },
  ];

  let equipments = [];
  try {
    const raw = document.getElementById('cfg_equipments').value;
    equipments = JSON.parse(raw) || [];
  } catch(e) { equipments = []; }

  let selectedIconId = null;

  function persist() {
    document.getElementById('cfg_equipments').value = JSON.stringify(equipments);
  }

  function renderList() {
    const list = document.getElementById('equipmentList');
    const noMsg = document.getElementById('noEquipmentMsg');
    list.innerHTML = '';
    if (equipments.length === 0) {
      noMsg.classList.remove('hidden');
      return;
    }
    noMsg.classList.add('hidden');
    equipments.forEach(function(eq, idx) {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 bg-gray-50 rounded-lg px-3 py-2 border';
      row.innerHTML =
        '<span class="w-6 h-6 flex-shrink-0 text-gray-600">' + eq.svg + '</span>' +
        '<span class="flex-1 text-sm">' + escapeHtml(eq.label) + '</span>' +
        '<button type="button" onclick="removeEquipment(' + idx + ')" class="text-red-400 hover:text-red-600 text-lg leading-none">&times;</button>';
      list.appendChild(row);
    });
  }

  function escapeHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderIconPicker() {
    const picker = document.getElementById('iconPicker');
    picker.innerHTML = '';
    ICONS.forEach(function(icon) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.title = icon.label;
      btn.dataset.iconId = icon.id;
      btn.className = 'flex flex-col items-center gap-1 p-2 rounded-lg border text-xs hover:bg-cyan-50 hover:border-cyan-400 transition icon-pick-btn';
      btn.innerHTML = '<span class="w-6 h-6 text-gray-600">' + icon.svg + '</span><span class="text-gray-500 text-[10px] truncate w-full text-center">' + icon.label + '</span>';
      btn.addEventListener('click', function() {
        selectedIconId = icon.id;
        document.querySelectorAll('.icon-pick-btn').forEach(function(b) {
          b.classList.remove('bg-cyan-50', 'border-cyan-400', 'ring-2', 'ring-cyan-400');
        });
        btn.classList.add('bg-cyan-50', 'border-cyan-400', 'ring-2', 'ring-cyan-400');
        document.getElementById('newEquipSvg').value = '';
      });
      picker.appendChild(btn);
    });
  }

  window.addEquipment = function() {
    const label = document.getElementById('newEquipLabel').value.trim();
    if (!label) { alert('Veuillez saisir un libellé.'); return; }

    let svg = '';
    const customSvg = document.getElementById('newEquipSvg').value.trim();
    if (customSvg) {
      svg = customSvg;
    } else if (selectedIconId) {
      const icon = ICONS.find(function(i) { return i.id === selectedIconId; });
      if (icon) svg = icon.svg;
    }
    if (!svg) { alert('Veuillez choisir une icône ou coller du SVG.'); return; }

    equipments.push({ svg: svg, label: label });
    persist();
    renderList();
    document.getElementById('newEquipLabel').value = '';
    document.getElementById('newEquipSvg').value = '';
    selectedIconId = null;
    document.querySelectorAll('.icon-pick-btn').forEach(function(b) {
      b.classList.remove('bg-cyan-50', 'border-cyan-400', 'ring-2', 'ring-cyan-400');
    });
  };

  window.removeEquipment = function(idx) {
    equipments.splice(idx, 1);
    persist();
    renderList();
  };

  renderIconPicker();
  renderList();
})();
</script>
