<div class="space-y-5">
  <input type="hidden" id="cfg_equipments" name="equipments" value="<%= JSON.stringify(config.equipments || []) %>" />

  <!-- Current equipment list -->
  <div>
    <h3 class="font-semibold mb-3">Équipements actuels</h3>
    <div id="equipmentList" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
      <!-- Populated by JS -->
    </div>
    <p id="noEquipmentMsg" class="text-sm text-gray-400 italic">Aucun équipement ajouté.</p>
  </div>

  <!-- Add new equipment -->
  <div class="border-t pt-5">
    <h3 class="font-semibold mb-4">Ajouter un équipement</h3>
    <div class="space-y-4">

      <!-- Label -->
      <div>
        <label class="text-sm font-medium text-gray-700 block mb-1">Libellé</label>
        <input type="text" id="newEquipLabel" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-cyan-400" placeholder="Ex. Sauna privatif" />
      </div>

      <!-- Icon picker -->
      <div>
        <label class="text-sm font-medium text-gray-700 block mb-2">Icône</label>

        <!-- Search -->
        <input type="text" id="iconSearch" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm mb-3 focus:outline-none focus:ring-2 focus:ring-cyan-400" placeholder="Rechercher une icône…" oninput="filterIcons(this.value)" />

        <!-- Category tabs -->
        <div class="flex flex-wrap gap-1 mb-3" id="categoryTabs"></div>

        <!-- Icons grid -->
        <div class="border rounded-xl p-3 bg-gray-50 max-h-72 overflow-y-auto">
          <div id="iconPicker" class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 lg:grid-cols-10 gap-1.5">
            <!-- Populated by JS -->
          </div>
          <p id="noIconResults" class="text-xs text-gray-400 text-center py-4 hidden">Aucune icône trouvée.</p>
        </div>

        <!-- Custom SVG -->
        <details class="mt-3">
          <summary class="text-xs text-gray-500 cursor-pointer select-none hover:text-gray-700">SVG personnalisé</summary>
          <textarea id="newEquipSvg" rows="3" class="mt-2 w-full rounded-lg border border-gray-300 px-3 py-2 text-xs font-mono focus:outline-none focus:ring-2 focus:ring-cyan-400" placeholder='<svg viewBox="0 0 24 24" fill="currentColor">...</svg>'></textarea>
        </details>
      </div>

      <button type="button" onclick="addEquipment()" class="px-5 py-2 rounded-lg bg-cyan-600 text-white text-sm font-medium hover:bg-cyan-700 active:scale-[.98] transition">
        + Ajouter
      </button>
    </div>
  </div>
</div>

